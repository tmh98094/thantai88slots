{
  "name": "thantai88slots",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run content:widgets && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cf:build": "npm run content:widgets && opennextjs-cloudflare build",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "deploy": "npm run content:daily-check && npm run cf:build && opennextjs-cloudflare deploy",
    "cf:dry-run": "npm run cf:build && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types cloudflare-env.d.ts --env-interface CloudflareEnv --include-runtime false",
    "ops:test": "node --test scripts/*.test.mjs",
    "seo:weekly": "node scripts/seo-weekly.mjs",
    "content:briefs": "node scripts/content-briefs.mjs",
    "content:drafts": "node scripts/content-drafts.mjs",
    "links:audit": "node scripts/links-audit.mjs",
    "content:daily-check": "node scripts/content-quality-check.mjs",
    "content:widgets": "node scripts/build-slots-widgets.mjs"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.107.0"
  }
}
